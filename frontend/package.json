{
  "name": "frontend",
  "version": "1.1.2",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "package": "svelte-kit package",
    "preview": "vite preview",
    "preview:local": "vite preview --host 127.0.0.1 --port 4175",
    "preview:open": "powershell -ExecutionPolicy Bypass -File .\\open-local-preview.ps1 -SkipBuild",
    "preview:open:fresh": "powershell -ExecutionPolicy Bypass -File .\\open-local-preview.ps1",
    "prepare": "svelte-kit sync",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "prettier --check --plugin-search-dir=. . && eslint .",
    "format": "prettier --write --plugin-search-dir=. ."
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.55.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@typescript-eslint/eslint-plugin": "^6.5.0",
    "@typescript-eslint/parser": "^6.5.0",
    "autoprefixer": "^10.4.15",
    "comlink": "^4.4.1",
    "eslint": "^8.48.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-svelte3": "^4.0.0",
    "postcss": "^8.4.29",
    "prettier": "^3.0.3",
    "prettier-plugin-svelte": "^3.0.3",
    "sass": "^1.93.2",
    "svelte": "^5.53.13",
    "svelte-canvas": "^0.9.3",
    "svelte-check": "^4.4.5",
    "svelte-preprocess": "^5.0.4",
    "svelte-select": "^5.7.0",
    "svelte-tiny-virtual-list": "^2.0.5",
    "tailwindcss": "^3.3.3",
    "tslib": "^2.6.2",
    "typescript": "^5.9.3",
    "vite": "^8.0.0"
  },
  "type": "module",
  "packageManager": "pnpm@9.15.9+sha512.68046141893c66fad01c079231128e9afb89ef87e2691d69e4d40eee228988295fd4682181bae55b58418c3a253bde65a505ec7c5f9403ece5cc3cd37dcf2531"
}
